{
  "compilerOptions": {
    "module": "esnext",
    "target": "ES2022",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "importHelpers": true,
    "sourceMap": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "paths": {
      "src/*": [
        "./src/*"
      ],
    }
  },
  "include": [
    "src"
  ],
  "files": [
    "src/resource.d.ts"
  ]
}
